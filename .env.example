# Kopiraj u .env.local i popuni (vidi Supabase → Settings → API).
# NIKAD ne commit-uj .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Ako Vercel/Supabase integracija doda publishable key umjesto anon key:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Server (API rute, RPC): obavezno za produkciju / punu funkcionalnost
# SUPABASE_SERVICE_ROLE_KEY=
